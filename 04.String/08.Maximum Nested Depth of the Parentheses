class Solution {
    public int maxDepth(String s) {
        int max = 0;
        int current =0;

        for(char ch : s.toCharArray()){
            if(ch =='('){
                current++;
            }else if(ch ==')'){
                current--;
            }else{
                continue;
            }
            max = Math.max(max, current);
        }
        return max;
    }
}
