/*Definition of doubly linked list:
class ListNode {
    int val;
    ListNode next;
    ListNode prev;

    ListNode() {
        val = 0;
        next = null;
        prev = null;
    }

    ListNode(int data1) {
        val = data1;
        next = null;
        prev = null;
    }

    ListNode(int data1, ListNode next1, ListNode prev1) {
        val = data1;
        next = next1;
        prev = prev1;
    }
}
 */

class Solution {
    public ListNode removeDuplicates(ListNode head) {
        if( head == null) return null;
        ListNode temp = head.next;

        while(temp != null){
            if(temp.val == temp.prev.val){
                ListNode front  = temp.next; 
                ListNode previ = temp.prev;
                previ.next = front;
                
                if(front != null){
                    front.prev = previ;
                }
            }
            temp= temp.next;
        }
        return head;
    }
}
