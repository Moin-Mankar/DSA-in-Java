class Solution {
    public Node copyRandomList(Node head) {
       if(head == null) return head;

       copyNodeinBetween(head);
       connectRandomNode(head);
       return getDeepCOpyNode(head);
}

public void copyNodeinBetween(Node head){
    Node temp = head;

    while(temp != null){
        Node nextNode = temp.next;
        Node copyNode = new Node (temp.val);

        temp.next = copyNode;
        copyNode.next= nextNode;

        temp = temp.next.next;
    }
}

public void connectRandomNode(Node head){
    Node temp = head;

    while(temp != null){
        Node copyNode = temp.next;

        if(temp.random != null){
            copyNode.random = temp.random.next;
        }else{
            copyNode.random = null;
        }
        temp = temp.next.next;
    }
}

public Node getDeepCOpyNode(Node head){
    Node DummyNode = new Node (-1);
    Node res  = DummyNode;
    Node temp = head;

    while(temp != null){
        res.next= temp.next;
        res = res.next;
        temp.next = temp.next.next;

        // res = res.next;
        temp = temp.next;
    }
    return DummyNode.next;
}
}
