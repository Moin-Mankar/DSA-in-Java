class Solution {
    public List<List<Integer>> findPairsWithGivenSum(ListNode head, int target) {
        List<List<Integer>> ans = new ArrayList<>();

        if(head == null) return ans;

        ListNode left = head;
        ListNode right = findTail(head);

        while(left != right && left.prev != right){
            if(left.val + right.val == target){
                ans.add(Arrays.asList(left.val, right.val));
                right = right.prev;
                left = left.next;
            }else if(left.val + right.val <target){
                left = left.next;
            }else{
                right = right.prev;
            }
        }
        return ans;
        
    }

    public ListNode findTail(ListNode head){
        ListNode tail = head;
        while(tail.next != null){
            tail = tail.next;
        }
        return tail;
    }
}
